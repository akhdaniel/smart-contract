<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="view_wizard_rekap_ketersediaan_sarlog_form" model="ir.ui.view">
            <field name="name">wizard.rekap.ketersediaan.sarlog.form</field>
            <field name="model">wizard.rekap.ketersediaan.sarlog</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Rekap Ketersediaan Sarlog">
                    <group>
                        <field name="year"/>
                    </group>
                    <footer>
                        <button name="action_export_excel" type="object" string="Export Excel" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action untuk membuka wizard -->
        <record id="action_wizard_rekap_ketersediaan_sarlog" model="ir.actions.act_window">
            <field name="name">Rekap Ketersediaan Sarlog</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">wizard.rekap.ketersediaan.sarlog</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Menu item placed after existing Realisasi RKAP Sarlog -->
        <menuitem id="vit_contract_menu_rekap_ketersediaan_sarlog"
                  name="Rekap Ketersediaan Sarlog"
                  parent="vit_contract_reporting_menu"
                  action="action_wizard_rekap_ketersediaan_sarlog"
                  sequence="20"/>
    </data>
</odoo>
